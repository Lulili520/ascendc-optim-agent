#include "kernel_operator.h"
#include "DiagPart_tiling.h"

using namespace AscendC;

class KernelDiagPart {
public:
    __aicore__ inline KernelDiagPart(TPipe* pipe)
    {
        pipe_ = pipe;
    };

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR out,
                                const __gm__ DiagPartTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t blockIdx = GetBlockIdx();
        N = tiling->N;

        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
        } else {
            total = tiling->tailNumLastCore;
        }

        startIdx = blockIdx * tiling->numPerCore;
        xGm_.SetGlobalBuffer((__gm__ half*)x);
        outGm_.SetGlobalBuffer((__gm__ half*)out);

        // Single-buffer queues (depth 1)
        pipe_->InitBuffer(inQueueX, 1, SUB_TILE * SUB_TILE * sizeof(half));
        pipe_->InitBuffer(outQueue, 1, TILE_LENGTH * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        uint32_t tileNum = (total + TILE_LENGTH - 1) / TILE_LENGTH;

        for (uint32_t t = 0; t < tileNum; t++) {
            uint32_t tileCount = (t == tileNum - 1) ? (total - t * TILE_LENGTH) : TILE_LENGTH;
            CopyInAndExtract(t * TILE_LENGTH, tileCount);
            CopyOut(t * TILE_LENGTH, tileCount);
        }
    }

    __aicore__ inline void CopyInAndExtract(uint32_t tileOffset, uint32_t tileCount)
    {
        auto outLocal = outQueue.AllocTensor<half>();

        uint32_t subTileNum = (tileCount + SUB_TILE - 1) / SUB_TILE;

        for (uint32_t s = 0; s < subTileNum; s++) {
            uint32_t subCount = (s == subTileNum - 1)
                ? (tileCount - s * SUB_TILE) : SUB_TILE;

            uint32_t diagStart = startIdx + tileOffset + s * SUB_TILE;

            auto xLocal = inQueueX.AllocTensor<half>();

            // Each diagonal element is at position diagStart+i on row diagStart+i
            // Load row by row using diagonal offset
            for (uint32_t i = 0; i < subCount; i++) {
                uint64_t elemOffset = ((uint64_t)diagStart + i) * ((uint64_t)N + 1);
                outLocal.SetValue(s * SUB_TILE + i, xGm_.GetValue(elemOffset));
            }

            inQueueX.FreeTensor(xLocal);
        }

        outQueue.EnQue(outLocal);
    }

    __aicore__ inline void CopyOut(uint32_t tileOffset, uint32_t tileCount)
    {
        auto outLocal = outQueue.DeQue<half>();
        uint64_t outOff = startIdx + tileOffset;
        DataCopyPad(outGm_[outOff], outLocal,
            {1, static_cast<uint16_t>(tileCount * sizeof(half)), 0, 0});
        outQueue.FreeTensor(outLocal);
    }

private:
    TPipe* pipe_;
    const __gm__ DiagPartTilingData* tiling;

    GlobalTensor<half> xGm_;
    GlobalTensor<half> outGm_;

    TQue<TPosition::VECIN, 1> inQueueX;
    TQue<TPosition::VECOUT, 1> outQueue;

    uint32_t total;
    uint32_t startIdx;
    uint64_t N;
};

extern "C" __global__ __aicore__ void DiagPart_kernel(GM_ADDR x, GM_ADDR out, GM_ADDR tiling)
{
    TPipe pipe;
    KernelDiagPart op(&pipe);
    op.Init(x, out, (__gm__ DiagPartTilingData*)tiling);
    op.Process();
}
