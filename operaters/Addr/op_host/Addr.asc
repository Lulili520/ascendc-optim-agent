#include <cstdint>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "../op_kernel/Addr_tiling.h"
#include "data_utils.h"
#include "../op_kernel/Addr_kernel.asc"

struct ArgInfo {
    std::string fileName;
    size_t length;
};

void KernelCall(uint32_t blockNum, aclrtStream stream,
    std::vector<ArgInfo> &inputsInfo, std::vector<ArgInfo> &outputsInfo,
    uint8_t *tilingData)
{
    std::vector<uint8_t *> inputHost(inputsInfo.size());
    std::vector<uint8_t *> inputDevice(inputsInfo.size());
    std::vector<uint8_t *> outputHost(outputsInfo.size());
    std::vector<uint8_t *> outputDevice(outputsInfo.size());
    uint8_t *tilingDevice = nullptr;

    aclrtMalloc((void **)&tilingDevice, sizeof(AddrTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tilingDevice, sizeof(AddrTilingData), tilingData,
        sizeof(AddrTilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    for (size_t i = 0; i < inputsInfo.size(); i++) {
        aclrtMallocHost((void **)&inputHost[i], inputsInfo[i].length);
        aclrtMalloc((void **)&inputDevice[i], inputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile(inputsInfo[i].fileName, inputsInfo[i].length, inputHost[i], inputsInfo[i].length);
        aclrtMemcpy(inputDevice[i], inputsInfo[i].length, inputHost[i],
            inputsInfo[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    for (size_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMallocHost((void **)&outputHost[i], outputsInfo[i].length);
        aclrtMalloc((void **)&outputDevice[i], outputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
    }

    Addr_kernel<<<blockNum, nullptr, stream>>>(
        inputDevice[0], inputDevice[1], inputDevice[2],
        outputDevice[0], tilingDevice);
    aclrtSynchronizeStream(stream);

    aclrtFree(tilingDevice);
    for (size_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMemcpy(outputHost[i], outputsInfo[i].length, outputDevice[i],
            outputsInfo[i].length, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile(outputsInfo[i].fileName, outputHost[i], outputsInfo[i].length);
        aclrtFree(outputDevice[i]);
        aclrtFreeHost(outputHost[i]);
    }

    for (size_t i = 0; i < inputsInfo.size(); i++) {
        aclrtFree(inputDevice[i]);
        aclrtFreeHost(inputHost[i]);
    }
}

int32_t main(int32_t argc, char *argv[])
{
    setbuf(stdout, NULL);
    setbuf(stderr, NULL);
    printf("A\n"); fflush(stdout);
    aclInit(nullptr);
    printf("B\n"); fflush(stdout);
    int32_t deviceId = 0;
    auto ret = aclrtSetDevice(deviceId);
    if (ret != ACL_SUCCESS) {
        printf("aclrtSetDevice failed, ret=%d\n", ret);
        return ret;
    }
    // Reset device to clear any residual state from previous kernel hangs
    aclrtResetDevice(deviceId);
    ret = aclrtSetDevice(deviceId);
    if (ret != ACL_SUCCESS) {
        printf("aclrtSetDevice(2) failed, ret=%d\n", ret);
        return ret;
    }
    printf("C\n"); fflush(stdout);

    int64_t maxCores = 0;
    ret = aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &maxCores);
    if (ret != ACL_SUCCESS) {
        printf("aclrtGetDeviceInfo failed, ret=%d\n", ret);
        aclrtResetDevice(deviceId);
        return ret;
    }

    uint64_t M = 512;
    uint64_t N = 1024;
    if (argc >= 3) {
        M = std::atoll(argv[1]);
        N = std::atoll(argv[2]);
    } else if (argc >= 2) {
        M = std::atoll(argv[1]);
    }

    float alpha = 1.0f;
    float beta = 1.0f;
    {
        std::ifstream af("./input/input_alpha.bin", std::ios::binary);
        if (af.is_open()) {
            af.read(reinterpret_cast<char*>(&alpha), sizeof(float));
        }
    }
    {
        std::ifstream bf("./input/input_beta.bin", std::ios::binary);
        if (bf.is_open()) {
            bf.read(reinterpret_cast<char*>(&beta), sizeof(float));
        }
    }

    uint64_t coreNum = M;
    if (coreNum > static_cast<uint64_t>(maxCores)) {
        coreNum = static_cast<uint64_t>(maxCores);
    }
    if (coreNum < 1) coreNum = 1;

    uint32_t rowsPerCore = static_cast<uint32_t>((M + coreNum - 1) / coreNum);
    uint32_t blockNum = static_cast<uint32_t>((M + rowsPerCore - 1) / rowsPerCore);
    if (blockNum > static_cast<uint32_t>(coreNum)) {
        blockNum = static_cast<uint32_t>(coreNum);
    }
    if (blockNum < 1) blockNum = 1;

    // DEBUG: test with configurable blockNum (optional 3rd arg)
    if (argc >= 4) {
        blockNum = static_cast<uint32_t>(std::atoll(argv[3]));
        rowsPerCore = static_cast<uint32_t>((M + blockNum - 1) / blockNum);
    }

    uint32_t ubFormer = UB_FORMER;
    if (N < ubFormer) {
        ubFormer = static_cast<uint32_t>(((N + DATA_ALIGN - 1) / DATA_ALIGN) * DATA_ALIGN);
    }

    uint32_t tailRowsLastCore = static_cast<uint32_t>(M - rowsPerCore * (blockNum - 1));
    if (tailRowsLastCore > rowsPerCore) tailRowsLastCore = rowsPerCore;

    AddrTilingData tiling;
    tiling.M = static_cast<uint32_t>(M);
    tiling.N = static_cast<uint32_t>(N);
    tiling.blockNum = blockNum;
    tiling.rowsPerCore = rowsPerCore;
    tiling.tailRowsLastCore = tailRowsLastCore;
    tiling.ubFormer = ubFormer;
    tiling.alpha = alpha;
    tiling.beta = beta;

    printf("Addr Tiling: M=%u, N=%u, blockNum=%u, rowsPerCore=%u, tailRowsLastCore=%u, ubFormer=%u, alpha=%.6f, beta=%.6f\n",
        tiling.M, tiling.N, tiling.blockNum, tiling.rowsPerCore, tiling.tailRowsLastCore, tiling.ubFormer, tiling.alpha, tiling.beta);

    size_t selfByteSize = M * N * sizeof(half);
    size_t vec1ByteSize = M * sizeof(half);
    size_t vec2ByteSize = N * sizeof(half);
    size_t outputByteSize = M * N * sizeof(half);

    std::vector<ArgInfo> inputsInfo = {
        {"./input/input_x1.bin", selfByteSize},
        {"./input/input_x2.bin", vec1ByteSize},
        {"./input/input_x3.bin", vec2ByteSize}
    };
    std::vector<ArgInfo> outputsInfo = {
        {"./output/output.bin", outputByteSize}
    };

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    KernelCall(blockNum, stream, inputsInfo, outputsInfo, (uint8_t *)&tiling);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
