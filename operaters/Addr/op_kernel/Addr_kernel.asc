#include "kernel_operator.h"
#include "Addr_tiling.h"

using namespace AscendC;

class KernelAddr {
public:
    __aicore__ inline KernelAddr(TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR x3, GM_ADDR y,
                                const __gm__ AddrTilingData* tiling)
    {
        tiling_ = tiling;
        uint32_t blockIdx = GetBlockIdx();
        N_ = tiling->N;

        if (blockIdx < tiling->blockNum - 1) {
            numRows_ = tiling->rowsPerCore;
        } else {
            numRows_ = tiling->tailRowsLastCore;
        }
        startRow_ = blockIdx * tiling->rowsPerCore;

        uint32_t ubFormer = tiling->ubFormer;
        tilesPerRow_ = (N_ + ubFormer - 1) / ubFormer;
        tailTileElements_ = N_ - ubFormer * (tilesPerRow_ - 1);

        selfGm_.SetGlobalBuffer((__gm__ half*)x1, tiling->M * N_);
        vec2Gm_.SetGlobalBuffer((__gm__ half*)x3, N_);
        outGm_.SetGlobalBuffer((__gm__ half*)y, tiling->M * N_);

        // Store vec1 GM base address as raw pointer for GetValue
        vec1GmPtr_ = (__gm__ half*)x2;

        // Allocate queues: single buffer each
        pipe_->InitBuffer(inQueueSelf_, 1, ubFormer * sizeof(half));
        pipe_->InitBuffer(inQueueVec2_, 1, ubFormer * sizeof(half));
        pipe_->InitBuffer(outQueue_, 1, ubFormer * sizeof(half));
        // tmpBuf for FP32: selfFp32 + vec2Fp32
        pipe_->InitBuffer(tmpBuf_, ubFormer * 2 * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        if (numRows_ == 0) return;

        float alphaVal = tiling_->alpha;
        float betaVal = tiling_->beta;
        uint32_t ubFormer = tiling_->ubFormer;

        for (uint32_t r = 0; r < numRows_; r++) {
            uint32_t row = startRow_ + r;

            // Read vec1[row] scalar from GM using offset access
            // Use vec2Gm (reused temporarily for 1-element vec1 load)
            // Actually, use selfGm for temporary scalar access pattern
            half vec1Vals[1];
            // Read from GM using the raw pointer
            vec1Vals[0] = vec1GmPtr_[row];
            float scale = alphaVal * static_cast<float>(vec1Vals[0]);

            for (uint32_t t = 0; t < tilesPerRow_; t++) {
                uint32_t count = (t == tilesPerRow_ - 1) ? tailTileElements_ : ubFormer;
                uint32_t colStart = t * ubFormer;
                uint32_t selfOffset = row * N_ + colStart;
                uint32_t vec2Offset = colStart;

                // Load self tile
                LocalTensor<half> selfLocal = inQueueSelf_.AllocTensor<half>();
                DataCopyPad(selfLocal, selfGm_[selfOffset],
                    {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0}, {false, 0, 0, 0});
                inQueueSelf_.EnQue(selfLocal);
                selfLocal = inQueueSelf_.DeQue<half>();

                // Load vec2 tile
                LocalTensor<half> vec2Local = inQueueVec2_.AllocTensor<half>();
                DataCopyPad(vec2Local, vec2Gm_[vec2Offset],
                    {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0}, {false, 0, 0, 0});
                inQueueVec2_.EnQue(vec2Local);
                vec2Local = inQueueVec2_.DeQue<half>();

                // FP32 compute
                int32_t cnt = static_cast<int32_t>(count);
                LocalTensor<float> tmpBuf = tmpBuf_.Get<float>();
                LocalTensor<float> selfFp32 = tmpBuf[0];
                LocalTensor<float> vec2Fp32 = tmpBuf[ubFormer];

                Cast<float, half>(selfFp32, selfLocal, RoundMode::CAST_NONE, cnt);
                inQueueSelf_.FreeTensor(selfLocal);

                Cast<float, half>(vec2Fp32, vec2Local, RoundMode::CAST_NONE, cnt);
                inQueueVec2_.FreeTensor(vec2Local);

                // Compute: out = beta * self + alpha * vec1[row] * vec2
                Muls(vec2Fp32, vec2Fp32, scale, cnt);
                Muls(selfFp32, selfFp32, betaVal, cnt);
                Add(selfFp32, selfFp32, vec2Fp32, cnt);

                // Cast back to FP16 and output
                LocalTensor<half> outLocal = outQueue_.AllocTensor<half>();
                Cast<half, float>(outLocal, selfFp32, RoundMode::CAST_ROUND, cnt);
                outQueue_.EnQue<half>(outLocal);
                outLocal = outQueue_.DeQue<half>();

                DataCopyPad(outGm_[selfOffset], outLocal,
                    {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0});
                outQueue_.FreeTensor(outLocal);
            }
        }
    }

private:
    TPipe* pipe_;
    const __gm__ AddrTilingData* tiling_;
    GlobalTensor<half> selfGm_;
    __gm__ half* vec1GmPtr_;
    GlobalTensor<half> vec2Gm_;
    GlobalTensor<half> outGm_;
    TQue<TPosition::VECIN, 1> inQueueSelf_;
    TQue<TPosition::VECIN, 1> inQueueVec2_;
    TQue<TPosition::VECOUT, 1> outQueue_;
    TBuf<TPosition::VECCALC> tmpBuf_;
    uint32_t startRow_;
    uint32_t numRows_;
    uint32_t N_;
    uint32_t tilesPerRow_;
    uint32_t tailTileElements_;
};

extern "C" __global__ __aicore__ void Addr_kernel(GM_ADDR x1, GM_ADDR x2, GM_ADDR x3,
                                                    GM_ADDR y, GM_ADDR tiling)
{
    TPipe pipe;
    KernelAddr op(&pipe);
    op.Init(x1, x2, x3, y, (__gm__ AddrTilingData*)tiling);
    op.Process();
}
