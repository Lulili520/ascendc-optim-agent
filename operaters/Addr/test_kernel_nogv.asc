#include "kernel_operator.h"

class KernelTest {
public:
    __aicore__ inline KernelTest(AscendC::TPipe* pipe) { pipe_ = pipe; };
    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR y) {
        selfGm.SetGlobalBuffer((__gm__ half*)x1, 1024);
        outGm.SetGlobalBuffer((__gm__ half*)y, 1024);
        pipe_->InitBuffer(inQueue, 1, 1024 * sizeof(half));
        pipe_->InitBuffer(outQueue, 1, 1024 * sizeof(half));
    }
    __aicore__ inline void Process() {
        AscendC::LocalTensor<half> inLocal = inQueue.AllocTensor<half>();
        AscendC::DataCopyPad(inLocal, selfGm[0], {1, 2048, 0, 0}, {false, 0, 0, 0});
        inQueue.EnQue(inLocal);
        AscendC::LocalTensor<half> inDeq = inQueue.DeQue<half>();
        AscendC::LocalTensor<half> outLocal = outQueue.AllocTensor<half>();
        AscendC::Adds(outLocal, inDeq, (half)1.0f, 1024);
        outQueue.EnQue(outLocal);
        AscendC::LocalTensor<half> outDeq = outQueue.DeQue<half>();
        AscendC::DataCopyPad(outGm[0], outDeq, {1, 2048, 0, 0});
        outQueue.FreeTensor(outDeq);
    }
private:
    AscendC::TPipe* pipe_;
    AscendC::GlobalTensor<half> selfGm;
    AscendC::GlobalTensor<half> outGm;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueue;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueue;
};

extern "C" __global__ __vector__ void test_kernel(GM_ADDR x1, GM_ADDR y) {
    AscendC::TPipe pipe;
    KernelTest op(&pipe);
    op.Init(x1, y);
    op.Process();
}
