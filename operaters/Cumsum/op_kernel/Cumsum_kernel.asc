#include "kernel_operator.h"
#include "Cumsum_tiling.h"

using namespace AscendC;

constexpr uint32_t CUMSUM_UB_TILE = 2048;

class KernelCumsum {
public:
    __aicore__ inline KernelCumsum(TPipe* pipe) { pipe_ = pipe; }

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y,
                                const __gm__ CumsumTilingData* tiling)
    {
        dim_ = tiling->dim;
        B_ = tiling->B;
        T_ = tiling->T;
        F_ = tiling->F;
        tileLen_ = tiling->tileLen;
        numFTiles_ = (F_ + tileLen_ - 1) / tileLen_;
        exclusive_ = tiling->exclusive;
        reverse_ = tiling->reverse;

        uint32_t blockIdx = GetBlockIdx();
        uint32_t laneGroups = tiling->laneGroupsPerCore;
        if (blockIdx == tiling->blockNum - 1) {
            laneGroups = tiling->tailLaneGroupsLastCore;
        }
        laneStart_ = blockIdx * tiling->laneGroupsPerCore;
        laneEnd_ = laneStart_ + laneGroups;

        xGm.SetGlobalBuffer((__gm__ half*)x);
        yGm.SetGlobalBuffer((__gm__ half*)y);

        pipe_->InitBuffer(inQueue_, 1, tileLen_ * sizeof(half));
        pipe_->InitBuffer(outQueue_, 1, tileLen_ * sizeof(half));
        pipe_->InitBuffer(tmpBuf_, CUMSUM_UB_TILE * 2 * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        for (uint32_t lane = laneStart_; lane < laneEnd_; lane++) {
            uint32_t bIdx = lane / numFTiles_;
            uint32_t fGroup = lane % numFTiles_;
            uint32_t fStart = fGroup * tileLen_;
            uint32_t fCount = (fStart + tileLen_ <= F_) ? tileLen_ : (F_ - fStart);

            LocalTensor<float> tmp = tmpBuf_.Get<float>();
            LocalTensor<float> accum = tmp[0];
            LocalTensor<float> src = tmp[CUMSUM_UB_TILE];

            // Init accumulator to zero
            Duplicate(accum, 0.0f, fCount);
            PipeBarrier<PIPE_V>();

            // Determine iteration count and base offset from dim
            // dim==1: iterate T elements for this (bIdx, fGroup)
            // dim==0: iterate B elements for this (tIdx, fGroup)
            // Both use the same loop body with different offset calculation
            uint32_t iterCount;
            if (dim_ == 0) {
                iterCount = B_;
            } else {
                iterCount = T_;
            }

            for (uint32_t i = 0; i < iterCount; i++) {
                uint32_t iter = reverse_ ? (iterCount - 1 - i) : i;

                uint64_t offset;
                if (dim_ == 0) {
                    // dim=0: offset = iter*T*F + bIdx*F + fStart
                    offset = (uint64_t)iter * T_ * F_ + bIdx * F_ + fStart;
                } else {
                    // dim=1: offset = bIdx*T*F + iter*F + fStart
                    offset = (uint64_t)bIdx * T_ * F_ + iter * F_ + fStart;
                }

                LocalTensor<half> inLocal = inQueue_.AllocTensor<half>();
                DataCopyPad(inLocal, xGm[offset],
                    {1, static_cast<uint16_t>(fCount * sizeof(half)), 0, 0},
                    {false, 0, 0, 0});
                inQueue_.EnQue(inLocal);
                inLocal = inQueue_.DeQue<half>();

                if (!exclusive_) {
                    // acc += x[i], then output acc
                    Cast<float, half>(src, inLocal, RoundMode::CAST_NONE, fCount);
                    Add<float>(accum, accum, src, fCount);
                    PipeBarrier<PIPE_V>();

                    LocalTensor<half> outLocal = outQueue_.AllocTensor<half>();
                    Cast<half, float>(outLocal, accum, RoundMode::CAST_ROUND, fCount);
                    outQueue_.EnQue(outLocal);
                    outLocal = outQueue_.DeQue<half>();
                    DataCopyPad(yGm[offset], outLocal,
                        {1, static_cast<uint16_t>(fCount * sizeof(half)), 0, 0});
                    outQueue_.FreeTensor(outLocal);
                } else {
                    // output acc (sum of x[0..i-1]), then acc += x[i]
                    LocalTensor<half> outLocal = outQueue_.AllocTensor<half>();
                    Cast<half, float>(outLocal, accum, RoundMode::CAST_ROUND, fCount);
                    outQueue_.EnQue(outLocal);
                    outLocal = outQueue_.DeQue<half>();
                    DataCopyPad(yGm[offset], outLocal,
                        {1, static_cast<uint16_t>(fCount * sizeof(half)), 0, 0});
                    outQueue_.FreeTensor(outLocal);

                    Cast<float, half>(src, inLocal, RoundMode::CAST_NONE, fCount);
                    Add<float>(accum, accum, src, fCount);
                    PipeBarrier<PIPE_V>();
                }

                inQueue_.FreeTensor(inLocal);
            }
        }
    }

private:
    TPipe* pipe_;
    TQue<TPosition::VECIN, 1> inQueue_;
    TQue<TPosition::VECOUT, 1> outQueue_;
    TBuf<TPosition::VECCALC> tmpBuf_;

    GlobalTensor<half> xGm;
    GlobalTensor<half> yGm;

    uint32_t dim_;
    uint32_t B_, T_, F_;
    uint32_t tileLen_;
    uint32_t numFTiles_;
    uint32_t laneStart_, laneEnd_;
    uint32_t exclusive_;
    uint32_t reverse_;
};

extern "C" __global__ __aicore__ void Cumsum_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR tiling)
{
    TPipe pipe;
    KernelCumsum op(&pipe);
    op.Init(x, y, (__gm__ CumsumTilingData*)tiling);
    op.Process();
}
