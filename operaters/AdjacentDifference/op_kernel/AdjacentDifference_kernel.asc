#include "kernel_operator.h"
#include "AdjacentDifference_tiling.h"

class KernelAdjacentDifference {
public:
    __aicore__ inline KernelAdjacentDifference(AscendC::TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y,
                                const __gm__ AdjacentDifferenceTilingData* tiling)
    {
        this->tiling = tiling;
        uint32_t coreId = AscendC::GetBlockIdx();
        uint32_t numCores = tiling->blockNum;
        ubFormer = tiling->ubFormer;

        // Use int16 global view for raw bit comparison
        xGmI16.SetGlobalBuffer((__gm__ int16_t*)x, tiling->totalLength);
        yGm.SetGlobalBuffer((__gm__ half*)y, tiling->totalLength);

        uint64_t coreStart = coreId * tiling->numPerCore;
        uint64_t coreEnd = (coreId == numCores - 1) ? tiling->totalLength
                                                    : (coreId + 1) * tiling->numPerCore;

        isCore0 = (coreId == 0);
        processStart = isCore0 ? 1 : coreStart;
        processLen = (coreEnd > processStart) ? (coreEnd - processStart) : 0;

        if (processLen == 0) {
            tileNum = 0;
            return;
        }

        tileNum = (processLen + ubFormer - 1) / ubFormer;
        tailElementNum = processLen - ubFormer * (tileNum - 1);

        // Single input queue for raw int16 data, load ubFormer+1 elements per tile
        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, (ubFormer + 16) * sizeof(int16_t));
        pipe_->InitBuffer(outQueueY, DOUBLE_BUFFER, ubFormer * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        if (tileNum == 0) return;

        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t curCount = (i == tileNum - 1) ? tailElementNum : ubFormer;
            CopyInComputeOut(curCount, i);
        }
    }

private:
    __aicore__ inline void CopyInComputeOut(uint32_t count, uint32_t tileIdx)
    {
        uint64_t rawStart = processStart + (uint64_t)tileIdx * ubFormer - 1;
        // Round down to 16-element (32-byte) alignment for GM load
        uint64_t alignedStart = (rawStart / DATA_ALIGN) * DATA_ALIGN;
        uint64_t loadOffset = rawStart - alignedStart;
        uint32_t loadCount = (uint32_t)(loadOffset + count + 1);
        // Round up loadCount to multiple of 16 for alignment
        uint32_t loadCountAligned = ((loadCount + 15) / 16) * 16;

        auto xLocal = inQueueX.AllocTensor<int16_t>();

        AscendC::DataCopy(xLocal, xGmI16[alignedStart], loadCountAligned);
        inQueueX.EnQue(xLocal);

        xLocal = inQueueX.DeQue<int16_t>();
        auto yLocal = outQueueY.AllocTensor<half>();

        // Scalar int16 comparison and half output via SetValue
        for (uint32_t i = 0; i < count; i++) {
            int16_t prevBits = xLocal.GetValue(loadOffset + i);
            int16_t curBits = xLocal.GetValue(loadOffset + 1 + i);
            // 0x3C00 = half(1.0), 0x0000 = half(0.0)
            int16_t outBits = (prevBits != curBits) ? 0x3C00 : 0x0000;
            yLocal.SetValue(i, *reinterpret_cast<half*>(&outBits));
        }

        outQueueY.EnQue<half>(yLocal);
        inQueueX.FreeTensor(xLocal);

        // CopyOut
        yLocal = outQueueY.DeQue<half>();
        uint64_t absOffset = processStart + (uint64_t)tileIdx * ubFormer;
        uint32_t byteLen = count * sizeof(half);
        AscendC::DataCopyExtParams copyParams{1, byteLen, 0, 0, 0};
        AscendC::DataCopyPad(yGm[absOffset], yLocal, copyParams);
        outQueueY.FreeTensor(yLocal);
    }

    AscendC::TPipe* pipe_;
    const __gm__ AdjacentDifferenceTilingData* tiling;

    AscendC::GlobalTensor<int16_t> xGmI16;
    AscendC::GlobalTensor<half> yGm;

    AscendC::TQue<AscendC::TPosition::VECIN, 2> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 2> outQueueY;

    uint32_t ubFormer;
    uint64_t processStart;
    uint64_t processLen;
    uint32_t tileNum;
    uint32_t tailElementNum;
    bool isCore0;
};

extern "C" __global__ __vector__ void AdjacentDifference_kernel(
    GM_ADDR x, GM_ADDR y, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelAdjacentDifference op(&pipe);
    op.Init(x, y, (__gm__ AdjacentDifferenceTilingData*)tiling);
    op.Process();
}
