#include "kernel_operator.h"
#include "Complex_tiling.h"

using namespace AscendC;

// Block-interleaved complex layout: [r0..r31, i0..i31, r32..r63, i32..i63, ...]
constexpr uint32_t BLOCK_SIZE = 32;

class KernelComplex {
public:
    __aicore__ inline KernelComplex(TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR real, GM_ADDR imag, GM_ADDR out,
                                const __gm__ ComplexTilingData* tiling)
    {
        tiling_ = tiling;
        uint32_t blockIdx = GetBlockIdx();

        if (blockIdx < tiling->blockNum - 1) {
            total_ = tiling->numPerCore;
        } else {
            total_ = tiling->tailNumLastCore;
        }

        tileNum_ = (total_ + TILE_LENGTH - 1) / TILE_LENGTH;
        tailTileElementNum_ = total_ - TILE_LENGTH * (tileNum_ - 1);

        realGm_.SetGlobalBuffer((__gm__ half*)real + blockIdx * tiling->numPerCore, total_);
        imagGm_.SetGlobalBuffer((__gm__ half*)imag + blockIdx * tiling->numPerCore, total_);
        outGm_.SetGlobalBuffer((__gm__ half*)out + blockIdx * tiling->numPerCore * 2, total_ * 2);

        pipe_->InitBuffer(realInQueue, 1, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(imagInQueue, 1, TILE_LENGTH * sizeof(half));
        pipe_->InitBuffer(outQueue, 1, 2 * TILE_LENGTH * sizeof(half));
    }

    __aicore__ inline void Process()
    {
        if (tileNum_ == 0) return;

        for (uint32_t i = 0; i < tileNum_; i++) {
            uint32_t count = (i == tileNum_ - 1) ? tailTileElementNum_ : TILE_LENGTH;
            CopyIn(count, i);
            Compute(count);
            CopyOut(count, i);
        }
    }

private:
    __aicore__ inline void CopyIn(uint32_t count, uint32_t tileIdx)
    {
        uint64_t offset = (uint64_t)tileIdx * TILE_LENGTH;
        uint16_t copyBytes = static_cast<uint16_t>(count * sizeof(half));

        LocalTensor<half> realLocal = realInQueue.AllocTensor<half>();
        if (count % 16 == 0) {
            DataCopy(realLocal, realGm_[offset], count);
        } else {
            DataCopyPad(realLocal, realGm_[offset],
                {1, copyBytes, 0, 0}, {false, 0, 0, 0});
        }
        realInQueue.EnQue<half>(realLocal);

        LocalTensor<half> imagLocal = imagInQueue.AllocTensor<half>();
        if (count % 16 == 0) {
            DataCopy(imagLocal, imagGm_[offset], count);
        } else {
            DataCopyPad(imagLocal, imagGm_[offset],
                {1, copyBytes, 0, 0}, {false, 0, 0, 0});
        }
        imagInQueue.EnQue<half>(imagLocal);
    }

    __aicore__ inline void Compute(uint32_t count)
    {
        LocalTensor<half> realLocal = realInQueue.DeQue<half>();
        LocalTensor<half> imagLocal = imagInQueue.DeQue<half>();
        LocalTensor<half> outLocal = outQueue.AllocTensor<half>();

        // Block-interleaved: for each BLOCK_SIZE chunk:
        //   out[2*blockPos : 2*blockPos + BLOCK_SIZE] = real[base : base + BLOCK_SIZE]
        //   out[2*blockPos + BLOCK_SIZE : 2*blockPos + 2*BLOCK_SIZE] = imag[base : base + BLOCK_SIZE]
        // Use vector Duplicate to copy each chunk (works for half type in VECOUT)
        uint32_t fullBlocks = count / BLOCK_SIZE;
        for (uint32_t b = 0; b < fullBlocks; b++) {
            uint32_t base = b * BLOCK_SIZE;
            uint32_t outBase = b * 2 * BLOCK_SIZE;
            // Copy real block
            for (uint32_t j = 0; j < BLOCK_SIZE; j++) {
                outLocal.SetValue(outBase + j, realLocal.GetValue(base + j));
            }
            // Copy imag block
            for (uint32_t j = 0; j < BLOCK_SIZE; j++) {
                outLocal.SetValue(outBase + BLOCK_SIZE + j, imagLocal.GetValue(base + j));
            }
        }

        // Handle tail
        uint32_t tailCount = count % BLOCK_SIZE;
        if (tailCount != 0) {
            uint32_t base = fullBlocks * BLOCK_SIZE;
            uint32_t outBase = fullBlocks * 2 * BLOCK_SIZE;
            for (uint32_t j = 0; j < tailCount; j++) {
                outLocal.SetValue(outBase + j, realLocal.GetValue(base + j));
            }
            for (uint32_t j = 0; j < tailCount; j++) {
                outLocal.SetValue(outBase + tailCount + j, imagLocal.GetValue(base + j));
            }
        }

        outQueue.EnQue<half>(outLocal);
        realInQueue.FreeTensor(realLocal);
        imagInQueue.FreeTensor(imagLocal);
    }

    __aicore__ inline void CopyOut(uint32_t count, uint32_t tileIdx)
    {
        LocalTensor<half> outLocal = outQueue.DeQue<half>();
        uint64_t offset = (uint64_t)tileIdx * TILE_LENGTH * 2;
        uint16_t outBytes = static_cast<uint16_t>(count * 2 * sizeof(half));
        if (outBytes % 32 == 0) {
            DataCopy(outGm_[offset], outLocal, count * 2);
        } else {
            DataCopyPad(outGm_[offset], outLocal,
                {1, outBytes, 0, 0});
        }
        outQueue.FreeTensor(outLocal);
    }

    TPipe* pipe_;
    const __gm__ ComplexTilingData* tiling_;
    GlobalTensor<half> realGm_;
    GlobalTensor<half> imagGm_;
    GlobalTensor<half> outGm_;

    TQue<TPosition::VECIN, 1> realInQueue;
    TQue<TPosition::VECIN, 1> imagInQueue;
    TQue<TPosition::VECOUT, 1> outQueue;

    uint32_t total_ = 0;
    uint32_t tileNum_ = 0;
    uint32_t tailTileElementNum_ = 0;
};

extern "C" __global__ __aicore__ void Complex_kernel(
    GM_ADDR real, GM_ADDR imag, GM_ADDR out, GM_ADDR tiling)
{
    TPipe pipe;
    KernelComplex op(&pipe);
    op.Init(real, imag, out, (__gm__ ComplexTilingData*)tiling);
    op.Process();
}
