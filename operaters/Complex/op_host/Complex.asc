#include "data_utils.h"
#include "Complex_tiling.h"
#include "Complex_kernel.asc"

#include <acl/acl.h>
#include <cstdint>
#include <cstdio>
#include <cstdlib>
#include <cstring>
#include <algorithm>

struct ArgInfo {
    const char* fileName;
    uint32_t byteLen;
};

void KernelCall(aclrtStream stream, uint32_t blockNum, ComplexTilingData& tilingData,
    const ArgInfo& realArg, const ArgInfo& imagArg, const ArgInfo& outArg)
{
    uint8_t* tilingHost = nullptr;
    uint8_t* tilingDevice = nullptr;
    aclrtMallocHost((void**)&tilingHost, sizeof(ComplexTilingData));
    aclrtMalloc((void**)&tilingDevice, sizeof(ComplexTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    memcpy(tilingHost, &tilingData, sizeof(ComplexTilingData));
    aclrtMemcpy(tilingDevice, sizeof(ComplexTilingData), tilingHost, sizeof(ComplexTilingData),
        ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* realHost = nullptr;
    uint8_t* realDevice = nullptr;
    aclrtMallocHost((void**)&realHost, realArg.byteLen);
    ReadFile(realArg.fileName, realArg.byteLen, realHost, realArg.byteLen);
    aclrtMalloc((void**)&realDevice, realArg.byteLen, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(realDevice, realArg.byteLen, realHost, realArg.byteLen, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* imagHost = nullptr;
    uint8_t* imagDevice = nullptr;
    aclrtMallocHost((void**)&imagHost, imagArg.byteLen);
    ReadFile(imagArg.fileName, imagArg.byteLen, imagHost, imagArg.byteLen);
    aclrtMalloc((void**)&imagDevice, imagArg.byteLen, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(imagDevice, imagArg.byteLen, imagHost, imagArg.byteLen, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* outHost = nullptr;
    uint8_t* outDevice = nullptr;
    aclrtMallocHost((void**)&outHost, outArg.byteLen);
    aclrtMalloc((void**)&outDevice, outArg.byteLen, ACL_MEM_MALLOC_HUGE_FIRST);

    Complex_kernel<<<blockNum, nullptr, stream>>>(realDevice, imagDevice, outDevice, tilingDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outHost, outArg.byteLen, outDevice, outArg.byteLen, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile(outArg.fileName, outHost, outArg.byteLen);

    aclrtFree(tilingDevice);
    aclrtFreeHost(tilingHost);
    aclrtFree(realDevice);
    aclrtFreeHost(realHost);
    aclrtFree(imagDevice);
    aclrtFreeHost(imagHost);
    aclrtFree(outDevice);
    aclrtFreeHost(outHost);
}

int main(int argc, char* argv[])
{
    // Shape definitions matching JSONL: [[4,2048,2048]]
    static const uint64_t shapeElements[] = {4*2048*2048};
    static const int numShapes = sizeof(shapeElements) / sizeof(shapeElements[0]);

    uint64_t totalLength = 0;
    if (argc > 1) {
        int idx = std::atoi(argv[1]);
        if (idx >= 0 && idx < numShapes) {
            totalLength = shapeElements[idx];
        } else {
            totalLength = std::atoll(argv[1]);
        }
    }
    if (totalLength == 0) totalLength = shapeElements[0];

    aclError ret = aclInit(nullptr);
    if (ret != ACL_SUCCESS && ret != ACL_ERROR_REPEAT_INITIALIZE) {
        printf("aclInit failed, ret=%d\n", ret);
        return 1;
    }
    ret = aclrtSetDevice(0);
    if (ret != ACL_SUCCESS) {
        printf("aclrtSetDevice failed, ret=%d\n", ret);
        return 1;
    }

    int64_t coreNum = 0;
    aclrtGetDeviceInfo(0, ACL_DEV_ATTR_VECTOR_CORE_NUM, &coreNum);

    // Tiling: distribute tiles across cores
    uint32_t tileNum = (totalLength + TILE_LENGTH - 1) / TILE_LENGTH;
    uint32_t blockNum = std::min(tileNum, static_cast<uint32_t>(coreNum));
    if (blockNum == 0) blockNum = 1;
    uint32_t tilesPerCore = (tileNum + blockNum - 1) / blockNum;
    uint32_t numPerCore = tilesPerCore * TILE_LENGTH;
    uint32_t tailNumLastCore = static_cast<uint32_t>(totalLength - (uint64_t)numPerCore * (blockNum - 1));

    ComplexTilingData tilingData;
    tilingData.blockNum = blockNum;
    tilingData.totalLength = totalLength;
    tilingData.numPerCore = numPerCore;
    tilingData.tailNumLastCore = tailNumLastCore;

    printf("Complex: totalLength=%lu, blockNum=%u, numPerCore=%u, tailNumLastCore=%u\n",
        (unsigned long)totalLength, blockNum, numPerCore, tailNumLastCore);

    uint32_t inputByteLen = totalLength * sizeof(uint16_t);
    uint32_t outputByteLen = totalLength * 2 * sizeof(uint16_t);

    ArgInfo realArg = {"./input/input_real.bin", inputByteLen};
    ArgInfo imagArg = {"./input/input_imag.bin", inputByteLen};
    ArgInfo outArg = {"./output/output.bin", outputByteLen};

    aclrtStream stream;
    aclrtCreateStream(&stream);
    KernelCall(stream, blockNum, tilingData, realArg, imagArg, outArg);
    aclrtDestroyStream(stream);

    aclrtResetDevice(0);
    aclFinalize();
    printf("Complex operator done.\n");
    return 0;
}
