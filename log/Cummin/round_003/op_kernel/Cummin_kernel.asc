#include "kernel_operator.h"
#include "Cummin_tiling.h"

using namespace AscendC;

constexpr uint32_t MAX_TILE = 512;

class KernelCummin {
public:
    __aicore__ inline KernelCummin(TPipe* pipe) : pipe_(pipe) {}

    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR argmin,
                                const __gm__ CumminTilingData* tiling)
    {
        dim_ = tiling->dim;
        B_ = tiling->B;
        T_ = tiling->T;
        F_ = tiling->F;
        tileLen_ = tiling->tileLen;
        numFTiles_ = (F_ + tileLen_ - 1) / tileLen_;

        uint32_t blockIdx = GetBlockIdx();
        uint32_t laneGroups = tiling->laneGroupsPerCore;
        if (blockIdx == tiling->blockNum - 1) {
            laneGroups = tiling->tailLaneGroupsLastCore;
        }
        laneStart_ = blockIdx * tiling->laneGroupsPerCore;
        laneEnd_ = laneStart_ + laneGroups;

        xGm.SetGlobalBuffer((__gm__ half*)x);
        yGm.SetGlobalBuffer((__gm__ half*)y);
        idxGm.SetGlobalBuffer((__gm__ int32_t*)argmin);

        pipe_->InitBuffer(inQue, 2, tileLen_ * sizeof(half));
        pipe_->InitBuffer(idxOutQue, 1, tileLen_ * sizeof(int32_t));
    }

    __aicore__ inline void Process()
    {
        for (uint32_t lane = laneStart_; lane < laneEnd_; lane++) {
            if (dim_ == 2) {
                ProcessDim2(lane);
            } else {
                ProcessDim01(lane);
            }
        }
    }

private:
    __aicore__ inline void CopyIn(uint64_t offset, uint32_t count)
    {
        LocalTensor<half> inLocal = inQue.AllocTensor<half>();
        DataCopyPad(inLocal, xGm[offset],
            {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0},
            {false, 0, 0, 0});
        inQue.EnQue(inLocal);
    }

    __aicore__ inline void ProcessDim01(uint32_t lane)
    {
        uint32_t outerIdx = lane / numFTiles_;
        uint32_t fGroup = lane % numFTiles_;
        uint32_t scanDim = (dim_ == 0) ? 0u : 1u;

        uint32_t fStart = fGroup * tileLen_;
        uint32_t fCount = (fStart + tileLen_ <= F_) ? tileLen_ : (F_ - fStart);
        uint32_t scanLen = (scanDim == 0) ? B_ : T_;

        half runningMin[MAX_TILE];
        int32_t runningIdx[MAX_TILE];
        for (uint32_t f = 0; f < fCount; f++) {
            runningMin[f] = (half)65504.0f;
            runningIdx[f] = 0;
        }

        // Pre-fetch first tile
        uint64_t offset0 = (scanDim == 0)
            ? (uint64_t)0 * T_ * F_ + outerIdx * F_ + fStart
            : (uint64_t)outerIdx * T_ * F_ + 0 * F_ + fStart;
        CopyIn(offset0, fCount);

        for (uint32_t step = 0; step < scanLen; step++) {
            uint64_t offset = (scanDim == 0)
                ? (uint64_t)step * T_ * F_ + outerIdx * F_ + fStart
                : (uint64_t)outerIdx * T_ * F_ + step * F_ + fStart;

            LocalTensor<half> xLocal = inQue.DeQue<half>();

            // Pre-fetch next tile (MTE2 overlaps with compute + MTE3 below)
            if (step < scanLen - 1) {
                uint64_t nextOff = (scanDim == 0)
                    ? (uint64_t)(step + 1) * T_ * F_ + outerIdx * F_ + fStart
                    : (uint64_t)outerIdx * T_ * F_ + (step + 1) * F_ + fStart;
                CopyIn(nextOff, fCount);
            }

            // Scalar compute: update running min + index
            for (uint32_t f = 0; f < fCount; f++) {
                half val = xLocal.GetValue(f);
                float vf = val;
                float mf = runningMin[f];
                if (vf < mf) {
                    runningMin[f] = val;
                    runningIdx[f] = (int32_t)step;
                }
                xLocal.SetValue(f, runningMin[f]);
            }

            // Launch value output (MTE3)
            DataCopyPad(yGm[offset], xLocal,
                {1, static_cast<uint16_t>(fCount * sizeof(half)), 0, 0});

            // Fill index output while value DMA is in flight
            LocalTensor<int32_t> idxLocal = idxOutQue.AllocTensor<int32_t>();
            for (uint32_t f = 0; f < fCount; f++) {
                idxLocal.SetValue(f, runningIdx[f]);
            }

            // Launch index output (MTE3)
            DataCopyPad(idxGm[offset], idxLocal,
                {1, static_cast<uint16_t>(fCount * sizeof(int32_t)), 0, 0});

            // Single barrier: waits for both output DMAs + pre-fetch DMA
            PipeBarrier<PIPE_ALL>();

            inQue.FreeTensor(xLocal);
            idxOutQue.FreeTensor(idxLocal);
        }
    }

    __aicore__ inline void ProcessDim2(uint32_t lane)
    {
        uint32_t bIdx = lane / T_;
        uint32_t tIdx = lane % T_;
        half rMin = (half)65504.0f;
        int32_t rIdx = 0;
        uint64_t baseOff = (uint64_t)bIdx * T_ * F_ + tIdx * F_;

        for (uint32_t f = 0; f < F_; f += tileLen_) {
            uint32_t bc = (f + tileLen_ <= F_) ? tileLen_ : (F_ - f);
            uint64_t gmOff = baseOff + f;

            LocalTensor<half> inLocal = inQue.AllocTensor<half>();
            DataCopyPad(inLocal, xGm[gmOff],
                {1, static_cast<uint16_t>(bc * sizeof(half)), 0, 0},
                {false, 0, 0, 0});
            inQue.EnQue(inLocal);
            LocalTensor<half> xLocal = inQue.DeQue<half>();

            int32_t bi[MAX_TILE];
            for (uint32_t j = 0; j < bc; j++) {
                half val = xLocal.GetValue(j);
                float vf = val;
                float mf = rMin;
                if (vf < mf) {
                    rMin = val;
                    rIdx = (int32_t)(f + j);
                }
                xLocal.SetValue(j, rMin);
                bi[j] = rIdx;
            }

            DataCopyPad(yGm[gmOff], xLocal,
                {1, static_cast<uint16_t>(bc * sizeof(half)), 0, 0});

            LocalTensor<int32_t> idxLocal = idxOutQue.AllocTensor<int32_t>();
            for (uint32_t j = 0; j < bc; j++) {
                idxLocal.SetValue(j, bi[j]);
            }
            DataCopyPad(idxGm[gmOff], idxLocal,
                {1, static_cast<uint16_t>(bc * sizeof(int32_t)), 0, 0});

            PipeBarrier<PIPE_ALL>();

            inQue.FreeTensor(xLocal);
            idxOutQue.FreeTensor(idxLocal);
        }
    }

private:
    TPipe* pipe_;
    TQue<QuePosition::VECIN, 2> inQue;
    TQue<QuePosition::VECOUT, 1> idxOutQue;

    GlobalTensor<half> xGm;
    GlobalTensor<half> yGm;
    GlobalTensor<int32_t> idxGm;

    uint32_t dim_;
    uint32_t B_, T_, F_;
    uint32_t tileLen_;
    uint32_t numFTiles_;
    uint32_t laneStart_, laneEnd_;
};

extern "C" __global__ __aicore__ void Cummin_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR argmin, GM_ADDR tiling)
{
    TPipe pipe;
    KernelCummin op(&pipe);
    op.Init(x, y, argmin, (__gm__ CumminTilingData*)tiling);
    op.Process();
}
