#include <cstdint>
#include <cstdio>
#include <cstring>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "../op_kernel/Cummin_tiling.h"
#include "data_utils.h"
#include "../op_kernel/Cummin_kernel.asc"

struct ArgInfo {
    std::string fileName;
    size_t length;
};

void KernelCall(uint32_t blockNum, aclrtStream stream,
    std::vector<ArgInfo> &inputsInfo, std::vector<ArgInfo> &outputsInfo,
    uint8_t *tilingData)
{
    std::vector<uint8_t *> inputHost(inputsInfo.size());
    std::vector<uint8_t *> inputDevice(inputsInfo.size());
    std::vector<uint8_t *> outputHost(outputsInfo.size());
    std::vector<uint8_t *> outputDevice(outputsInfo.size());
    uint8_t *tilingDevice = nullptr;

    aclrtMalloc((void **)&tilingDevice, sizeof(CumminTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tilingDevice, sizeof(CumminTilingData), tilingData,
        sizeof(CumminTilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    for (size_t i = 0; i < inputsInfo.size(); i++) {
        aclrtMallocHost((void **)&inputHost[i], inputsInfo[i].length);
        aclrtMalloc((void **)&inputDevice[i], inputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile(inputsInfo[i].fileName, inputsInfo[i].length, inputHost[i], inputsInfo[i].length);
        aclrtMemcpy(inputDevice[i], inputsInfo[i].length, inputHost[i],
            inputsInfo[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    for (size_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMallocHost((void **)&outputHost[i], outputsInfo[i].length);
        aclrtMalloc((void **)&outputDevice[i], outputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
    }

    Cummin_kernel<<<blockNum, nullptr, stream>>>(
        inputDevice[0], outputDevice[0], outputDevice[1], tilingDevice);
    aclrtSynchronizeStream(stream);

    aclrtFree(tilingDevice);
    for (size_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMemcpy(outputHost[i], outputsInfo[i].length, outputDevice[i],
            outputsInfo[i].length, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile(outputsInfo[i].fileName, outputHost[i], outputsInfo[i].length);
        aclrtFree(outputDevice[i]);
        aclrtFreeHost(outputHost[i]);
    }

    for (size_t i = 0; i < inputsInfo.size(); i++) {
        aclrtFree(inputDevice[i]);
        aclrtFreeHost(inputHost[i]);
    }
}

int32_t main(int32_t argc, char *argv[])
{
    if (argc < 5) {
        printf("Usage: %s <B> <T> <F> <dim>\n", argv[0]);
        return 1;
    }

    uint32_t B = atoi(argv[1]);
    uint32_t T = atoi(argv[2]);
    uint32_t F = atoi(argv[3]);
    uint32_t dim = atoi(argv[4]);
    if (B == 0 || T == 0 || F == 0) {
        printf("Error: B, T, F must be > 0\n");
        return 1;
    }

    uint32_t totalElements = B * T * F;
    size_t inputByteSize = totalElements * sizeof(uint16_t);   // float16
    size_t outputValByteSize = totalElements * sizeof(uint16_t);
    size_t outputIdxByteSize = totalElements * sizeof(int32_t);  // int32 on device

    aclInit(nullptr);
    int32_t deviceId = 0;
    auto ret = aclrtSetDevice(deviceId);
    if (ret != ACL_SUCCESS) {
        printf("aclrtSetDevice failed, ret=%d\n", ret);
        return ret;
    }

    int64_t availableCoreNum = 0;
    ret = aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &availableCoreNum);
    if (ret != ACL_SUCCESS) {
        printf("aclrtGetDeviceInfo failed, ret=%d\n", ret);
        aclrtResetDevice(deviceId);
        return ret;
    }

    uint32_t tileLen = (F < CUMMIN_TILE_LEN) ? F : CUMMIN_TILE_LEN;
    // Adjust tileLen to evenly divide F for load balance across cores
    if (F % tileLen != 0 && tileLen > 1) {
        uint32_t candidate = tileLen;
        while (candidate >= 16 && F % candidate != 0) {
            candidate--;
        }
        if (candidate >= 16) {
            tileLen = candidate;
        }
    }
    uint32_t numFTiles = (F + tileLen - 1) / tileLen;

    uint32_t numLaneGroups;
    if (dim == 0) {
        numLaneGroups = T * numFTiles;
    } else if (dim == 1) {
        numLaneGroups = B * numFTiles;
    } else {
        numLaneGroups = B * T;
    }

    uint32_t blockNum = (numLaneGroups < availableCoreNum) ? numLaneGroups : availableCoreNum;
    uint32_t laneGroupsPerCore = numLaneGroups / blockNum;
    uint32_t tailLaneGroupsLastCore = numLaneGroups - laneGroupsPerCore * (blockNum - 1);

    CumminTilingData tiling;
    tiling.blockNum = blockNum;
    tiling.dim = dim;
    tiling.B = B;
    tiling.T = T;
    tiling.F = F;
    tiling.totalElements = totalElements;
    tiling.tileLen = tileLen;
    tiling.numLaneGroups = numLaneGroups;
    tiling.laneGroupsPerCore = laneGroupsPerCore;
    tiling.tailLaneGroupsLastCore = tailLaneGroupsLastCore;

    printf("Cummin: shape=[%u,%u,%u] dim=%u totalElements=%u\n", B, T, F, dim, totalElements);
    printf("  tileLen=%u numFTiles=%u numLaneGroups=%u\n", tileLen, numFTiles, numLaneGroups);
    printf("  blockNum=%u laneGroupsPerCore=%u tailLaneGroupsLastCore=%u\n",
        blockNum, laneGroupsPerCore, tailLaneGroupsLastCore);

    std::vector<ArgInfo> inputsInfo = {
        {"./input/input_x.bin", inputByteSize}
    };
    std::vector<ArgInfo> outputsInfo = {
        {"./output/output_y.bin", outputValByteSize},
        {"./output/output_argmin.bin", outputIdxByteSize}
    };

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    KernelCall(blockNum, stream, inputsInfo, outputsInfo, (uint8_t *)&tiling);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    printf("Cummin kernel done.\n");
    return 0;
}
