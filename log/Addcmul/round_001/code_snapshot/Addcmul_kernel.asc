#include "kernel_operator.h"
#include "Addcmul_tiling.h"

class KernelAddcmul {
public:
    __aicore__ inline KernelAddcmul(AscendC::TPipe* pipe) { pipe_ = pipe; };

    __aicore__ inline void Init(GM_ADDR self, GM_ADDR tensor1, GM_ADDR tensor2, GM_ADDR out,
                                const __gm__ AddcmulTilingData* tiling)
    {
        uint32_t blockIdx = AscendC::GetBlockIdx();
        uint32_t tBlockNum = tiling->blockNum;
        uint32_t tNumPerCore = tiling->numPerCore;
        uint32_t tTailNumLastCore = tiling->tailNumLastCore;
        float tValue = tiling->value;

        value_ = tValue;

        if (blockIdx < tBlockNum - 1) {
            total_ = tNumPerCore;
        } else {
            total_ = tTailNumLastCore;
        }

        if (total_ == 0) return;

        selfGm_.SetGlobalBuffer((__gm__ half*)self + blockIdx * tNumPerCore, total_);
        t1Gm_.SetGlobalBuffer((__gm__ half*)tensor1 + blockIdx * tNumPerCore, total_);
        t2Gm_.SetGlobalBuffer((__gm__ half*)tensor2 + blockIdx * tNumPerCore, total_);
        outGm_.SetGlobalBuffer((__gm__ half*)out + blockIdx * tNumPerCore, total_);

        // Double-buffer queues with bank-conflict padding on input queue
        pipe_->InitBuffer(inQueue_, DOUBLE_BUFFER, UB_TILE * sizeof(half) + 128);
        pipe_->InitBuffer(outQueue_, DOUBLE_BUFFER, UB_TILE * sizeof(half));
        // FP32 temp buffer: 3 regions (t1_fp32, t2_fp32, self_fp32)
        pipe_->InitBuffer(tmpBufFP32_, 3 * UB_TILE * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        if (total_ == 0) return;

        uint32_t tileNum = (total_ + UB_TILE - 1) / UB_TILE;
        uint32_t tailElementNum = total_ - UB_TILE * (tileNum - 1);

        // Prefetch first tile: copy t1 into inQueue buffer[0]
        uint32_t firstCount = (tileNum == 1) ? tailElementNum : UB_TILE;
        CopyInT1(firstCount, 0);

        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t curCount = (i == tileNum - 1) ? tailElementNum : UB_TILE;
            int32_t cnt = static_cast<int32_t>(curCount);
            uint32_t offset = i * UB_TILE;

            AscendC::DataCopyParams cp = {1, static_cast<uint16_t>(curCount * sizeof(half)), 0, 0};

            // FP32 temp regions
            AscendC::LocalTensor<float> tmpBuf = tmpBufFP32_.Get<float>();
            AscendC::LocalTensor<float> t1Fp32 = tmpBuf[0];
            AscendC::LocalTensor<float> t2Fp32 = tmpBuf[UB_TILE];
            AscendC::LocalTensor<float> selfFp32 = tmpBuf[2 * UB_TILE];

            // --- Compute: t1 was already prefetched ---
            AscendC::LocalTensor<half> t1Local = inQueue_.DeQue<half>();
            AscendC::Cast<float, half>(t1Fp32, t1Local, AscendC::RoundMode::CAST_NONE, cnt);
            inQueue_.FreeTensor(t1Local);

            // CopyIn t2 + self (serial within Compute, but CopyOut overlaps with next iteration's prefetch)
            AscendC::LocalTensor<half> t2Local = inQueue_.AllocTensor<half>();
            AscendC::DataCopyPad(t2Local, t2Gm_[offset], cp, {false, 0, 0, 0});
            inQueue_.EnQue(t2Local);
            t2Local = inQueue_.DeQue<half>();
            AscendC::Cast<float, half>(t2Fp32, t2Local, AscendC::RoundMode::CAST_NONE, cnt);
            inQueue_.FreeTensor(t2Local);

            // t1_fp32 = t1 * t2
            AscendC::Mul(t1Fp32, t1Fp32, t2Fp32, cnt);
            // t1_fp32 = value * (t1 * t2)
            AscendC::Muls(t1Fp32, t1Fp32, value_, cnt);

            AscendC::LocalTensor<half> selfLocal = inQueue_.AllocTensor<half>();
            AscendC::DataCopyPad(selfLocal, selfGm_[offset], cp, {false, 0, 0, 0});
            inQueue_.EnQue(selfLocal);
            selfLocal = inQueue_.DeQue<half>();
            AscendC::Cast<float, half>(selfFp32, selfLocal, AscendC::RoundMode::CAST_NONE, cnt);
            inQueue_.FreeTensor(selfLocal);

            // result = self + value*(t1*t2)
            AscendC::Add(t1Fp32, selfFp32, t1Fp32, cnt);

            // Cast back to FP16 and copy out
            AscendC::LocalTensor<half> outLocal = outQueue_.AllocTensor<half>();
            AscendC::Cast<half, float>(outLocal, t1Fp32, AscendC::RoundMode::CAST_ROUND, cnt);
            outQueue_.EnQue<half>(outLocal);
            outLocal = outQueue_.DeQue<half>();
            AscendC::DataCopyPad(outGm_[offset], outLocal, cp);
            outQueue_.FreeTensor(outLocal);

            // Prefetch next tile's t1 (MTE2 overlaps with current CopyOut MTE3 hardware)
            if (i < tileNum - 1) {
                uint32_t nextCount = (i + 1 == tileNum - 1) ? tailElementNum : UB_TILE;
                CopyInT1(nextCount, i + 1);
            }
        }
    }

private:
    __aicore__ inline void CopyInT1(uint32_t count, uint32_t tileIdx)
    {
        uint32_t offset = tileIdx * UB_TILE;
        AscendC::DataCopyParams cp = {1, static_cast<uint16_t>(count * sizeof(half)), 0, 0};
        AscendC::LocalTensor<half> t1Local = inQueue_.AllocTensor<half>();
        AscendC::DataCopyPad(t1Local, t1Gm_[offset], cp, {false, 0, 0, 0});
        inQueue_.EnQue(t1Local);
    }

    AscendC::TPipe* pipe_;
    uint32_t total_;
    float value_;

    AscendC::GlobalTensor<half> selfGm_;
    AscendC::GlobalTensor<half> t1Gm_;
    AscendC::GlobalTensor<half> t2Gm_;
    AscendC::GlobalTensor<half> outGm_;

    AscendC::TQue<AscendC::TPosition::VECIN, 2> inQueue_;
    AscendC::TQue<AscendC::TPosition::VECOUT, 2> outQueue_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBufFP32_;
};

extern "C" __global__ __aicore__ void Addcmul_kernel(GM_ADDR self, GM_ADDR tensor1, GM_ADDR tensor2,
                                                      GM_ADDR out, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelAddcmul op(&pipe);
    op.Init(self, tensor1, tensor2, out, (__gm__ AddcmulTilingData*)tiling);
    op.Process();
}
